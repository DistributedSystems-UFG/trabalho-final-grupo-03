        RA_A2["ReplicaAgent\nshard-A r2 :50052"]
        RA_B1["ReplicaAgent\nshard-B r1 :50053"]
        RA_B2["ReplicaAgent\nshard-B r2 :50054"]
        RA_C1["ReplicaAgent\nshard-C r1 :50055"]
        RA_C2["ReplicaAgent\nshard-C r2 :50056"]
    end